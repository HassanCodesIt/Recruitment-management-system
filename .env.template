# =====================================================
# Recruitment Management System - Configuration
# =====================================================

# Database Configuration
DB_NAME=recruitment_management_system
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Email Configuration (Gmail)
EMAIL=your_email@gmail.com
PASSWORD=your_app_specific_password_here
IMAP_SERVER=imap.gmail.com

# AI/ML API Keys
GROQ_API_KEY=your_groq_api_key_here

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# FastAPI Configuration (Optional)
API_SERVER_PORT=8000
API_SERVER_HOST=0.0.0.0

# Screening Configuration
DEFAULT_SEMANTIC_WEIGHT=0.7
DEFAULT_SKILL_WEIGHT=0.3
DEFAULT_EXPERIENCE_WEIGHT=0.0
MIN_SCORE_THRESHOLD=50

# Duplicate Detection
DUPLICATE_NAME_THRESHOLD=85
DUPLICATE_PHONE_THRESHOLD=90

# File Storage
UPLOAD_FOLDER=uploads/resumes
MAX_FILE_SIZE_MB=10

# Email Fetching
EMAIL_FETCH_INTERVAL_HOURS=1
MARK_EMAILS_AS_READ=false
